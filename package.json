{
  "name": "@agentai2026/openclaw-zh",
  "version": "2026.5.30-zh",
  "description": "OpenClaw 汉化发行版 - 全中文界面，每小时自动同步官方 openclaw/openclaw 更新",
  "keywords": [
    "openclaw",
    "openclaw-zh",
    "chinese",
    "汉化",
    "ai",
    "assistant",
    "gateway",
    "telegram",
    "discord"
  ],
  "homepage": "https://github.com/agentai2026/openclaw-zh#readme",
  "bugs": {
    "url": "https://github.com/agentai2026/openclaw-zh/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentai2026/openclaw-zh.git"
  },
  "license": "MIT",
  "author": "agentai2026",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "bin": {
    "openclaw": "openclaw.mjs",
    "openclaw-zh": "openclaw.mjs"
  },
  "main": "openclaw.mjs",
  "scripts": {
    "sync": "node scripts/sync-upstream.js",
    "package:zh": "node scripts/apply-package-zh.js",
    "i18n": "node scripts/apply-i18n.js",
    "version:bump": "node scripts/bump-version.js",
    "release:local": "node scripts/sync-upstream.js && node scripts/apply-package-zh.js && node scripts/apply-i18n.js && node scripts/bump-version.js",
    "build": "pnpm run build:openclaw",
    "build:openclaw": "node -e \"console.log('[build] 请在 CI 或完整克隆后执行 pnpm run build')\""
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "openclaw.mjs",
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "npm-shrinkwrap.json"
  ]
}
